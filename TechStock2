    // ==================== LOGIN ====================
    static void fazerLogin() {
        int tentativas = 3; // 3 tentativas antes de fechar

        while (tentativas > 0) {
            System.out.print("\nUsuario: ");
            String loginDigitado = teclado.nextLine();

            System.out.print("Senha: ");
            String senhaDigitada = teclado.nextLine();

            if (senhaDigitada.length() < 8) {
                System.out.println("Erro: A senha deve ter pelo menos 8 caracteres!");
                tentativas = tentativas - 1;
                System.out.print("Tentativas restantes: " + tentativas + "\n");
                continue; // volta pro início do while
            }

            Usuario usuarioEncontrado = procurarUsuario(loginDigitado, senhaDigitada);

            if (usuarioEncontrado != null) {
                usuarioLogado = usuarioEncontrado;
                System.out.println("\nLogin realizado com sucesso!");
                System.out.print("Bem-vindo(a), " + usuarioLogado.nome + "\n");
                mostrarMenuPrincipal();
                return;
            } else
            {
                tentativas = tentativas - 1;
                System.out.println("Usuario ou senha incorretos!");
                System.out.print("Tentativas restantes: " + tentativas + "\n");
            }
        }

        System.out.println("\nNumero maximo de tentativas atingido.");
        System.out.print("Sistema encerrado.\n");
    }

    static Usuario procurarUsuario(String login, String senha) {
        for (int i = 0; i < listaUsuarios.size(); i++) {
            Usuario u = listaUsuarios.get(i);
            if (u.login.equals(login) && u.senha.equals(senha)) {
