            } else if (opcao == 4) {
                System.out.print("Voltando...\n");
            } else {
                System.out.println("Opcao invalida!");
            }
        }
    }

    static void removerFuncionario() {
        System.out.print("\n========== REMOVER FUNCIONARIO ==========\n");
        if (listaUsuarios.size() == 0) {
            System.out.println("Nenhum funcionario cadastrado.");
            return;
        }



        System.out.println("Funcionarios cadastrados:");
        for (int i = 0; i < listaUsuarios.size(); i++) {
            Usuario u = listaUsuarios.get(i);
            System.out.println((i+1) + " - " + u.nome + " (" + u.login + ") - " + u.tipo);
        }

        System.out.print("Digite o login do funcionario a remover: ");
        String loginRemover = teclado.nextLine();

        Usuario usuarioRemover = null;
        for (int i = 0; i < listaUsuarios.size(); i++) {
            if (listaUsuarios.get(i).login.equals(loginRemover)) {
                usuarioRemover = listaUsuarios.get(i);
                break;
            }
        }

        if (usuarioRemover == null) {
            System.out.println("Funcionario nao encontrado.");
            return;
        }
        if (usuarioRemover.login.equals(usuarioLogado.login)) {
            System.out.println("Voce nao pode remover seu proprio usuario!");
            return;
        }

        usuarioRemover.mostrarDados();
        System.out.print("Tem certeza que deseja remover este funcionario? (s/n): ");
        String confirmacao = teclado.nextLine();
        if (confirmacao.equals("s")) {
            listaUsuarios.remove(usuarioRemover);
            System.out.println("Funcionario removido com sucesso!");
        } else {
            System.out.println("Remocao cancelada.");
        }
    }

    static Produto buscarPorCodigo(String codigo) {
        for (int i = 0; i < listaProdutos.size(); i++) {
            Produto p = listaProdutos.get(i);
            if (p.codigo.equalsIgnoreCase(codigo)) {
                return p;
            }
        }
        return null;
    }
